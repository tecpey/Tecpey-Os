{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tecpey.ir/schemas/api-security-manifest.schema.json",
  "title": "TecPey API Security Manifest",
  "type": "object",
  "required": ["schemaVersion", "authority", "methods", "totals", "routes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "authority": { "const": "generated-from-src-app-api-route-ts" },
    "methods": {
      "type": "array",
      "items": { "enum": ["POST", "PUT", "PATCH", "DELETE"] },
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true
    },
    "totals": {
      "type": "object",
      "required": ["routeFiles", "mutatingOperations", "operationsWithFindings", "findings"]
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "route",
          "method",
          "sourcePath",
          "sourceHash",
          "classification",
          "risk",
          "controls",
          "domainOwner",
          "testReferences",
          "findings"
        ]
      }
    }
  }
}

# TecPey shared environment example
DEFAULT_LANGUAGE=fa
NEXT_PUBLIC_SITE_URL=https://tecpey.ir
NEXT_PUBLIC_API_URL=https://my.tecpey.ir

# AI Mentor - real keys are added only by the project owner on the server.
OPENAI_API_KEY=
AI_MENTOR_MODEL=gpt-4o-mini
AI_MENTOR_FALLBACK_MODEL=gpt-4.1-mini
AI_MENTOR_MAX_OUTPUT_TOKENS=700
AI_MENTOR_TEMPERATURE=0.2
AI_MENTOR_BUDGET_NOTE=gpt-4o-mini is the low-cost default; upgrade to gpt-4.1-mini or gpt-5.4-mini only if needed.

# AI Mentor V2 — Behavioral Intelligence (Claude API)
ANTHROPIC_API_KEY=
ANTHROPIC_MENTOR_MODEL=claude-haiku-4-5-20251001

# Required for production security.
TECPEY_ACADEMY_AUTH_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_ACADEMY_AUTH
TECPEY_SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_STUDENT_SESSIONS
CERTIFICATE_SIGNING_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_CERTIFICATE_SIGNING
DATABASE_URL=postgresql://tecpey:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/tecpey
# Keep empty on production. Set true only for localhost test without PostgreSQL.
TECPEY_ENABLE_LOCAL_ACADEMY_STORAGE=
REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Replace after final market backend handoff.
NEXT_PUBLIC_API_BACKEND_URL=https://CHANGE_ME_ADMIN_MARKET_BACKEND
NEXT_PUBLIC_API_SOCKET_URL=wss://CHANGE_ME_MARKET_SOCKET/spot

# TecPey Global Learning OS / Command Center
TECPEY_ADMIN_TOKEN=
TECPEY_NOTIFICATION_DEFAULT_CHANNELS=in_app,push,email,telegram
TECPEY_PUSH_PROVIDER=firebase
TECPEY_ANDROID_PACKAGE=
TECPEY_IOS_BUNDLE_ID=
TECPEY_FCM_SERVER_KEY=
TECPEY_APNS_KEY_ID=
TECPEY_APNS_TEAM_ID=
TECPEY_APNS_BUNDLE_ID=
TECPEY_APNS_PRIVATE_KEY=

# TecPey shared environment example
DEFAULT_LANGUAGE=fa
NEXT_PUBLIC_SITE_URL=https://tecpey.ir
NEXT_PUBLIC_API_URL=https://my.tecpey.ir

# AI Mentor V1 — OpenAI (primary, Persian-language mentor)
# Real keys are added only by the project owner on the server.
OPENAI_API_KEY=
# OPENAI_PROJECT_API_KEY is an alternative to OPENAI_API_KEY for project-scoped keys.
OPENAI_PROJECT_API_KEY=
AI_MENTOR_MODEL=gpt-4o-mini
AI_MENTOR_FALLBACK_MODEL=gpt-4.1-mini
AI_MENTOR_MAX_OUTPUT_TOKENS=700
AI_MENTOR_TEMPERATURE=0.2
AI_MENTOR_BUDGET_NOTE=gpt-4o-mini is the low-cost default; upgrade to gpt-4.1-mini or gpt-5.4-mini only if needed.
# Set to "off" to disable the cost-guard short-circuit for simple questions.
AI_MENTOR_COST_GUARD=

# AI Mentor V2 — Behavioral Intelligence (Claude API)
ANTHROPIC_API_KEY=
ANTHROPIC_MENTOR_MODEL=claude-haiku-4-5-20251001

# Required for production security.
TECPEY_ACADEMY_AUTH_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_ACADEMY_AUTH
TECPEY_SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_STUDENT_SESSIONS
CERTIFICATE_SIGNING_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_CERTIFICATE_SIGNING
DATABASE_URL=postgresql://tecpey:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/tecpey
# Keep empty on production. Set true only for localhost testing without PostgreSQL.
TECPEY_ENABLE_LOCAL_ACADEMY_STORAGE=

# Redis — REQUIRED IN PRODUCTION for correct rate limiting.
# Without Redis, rate limits are in-memory per process instance and do not
# coordinate across multiple server instances. A single user can bypass limits
# by hitting different instances. Configure at least one of the following:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy direct Redis URL (used by some adapters — Upstash REST is preferred):
REDIS_URL=redis://127.0.0.1:6379
REDIS_REST_URL=
REDIS_REST_TOKEN=

# Replace after final market backend handoff.
NEXT_PUBLIC_API_BACKEND_URL=https://CHANGE_ME_ADMIN_MARKET_BACKEND
NEXT_PUBLIC_API_SOCKET_URL=wss://CHANGE_ME_MARKET_SOCKET/spot

# TecPey Global Learning OS / Command Center
TECPEY_ADMIN_TOKEN=
TECPEY_NOTIFICATION_DEFAULT_CHANNELS=in_app,push,email,telegram
TECPEY_PUSH_PROVIDER=firebase
TECPEY_ANDROID_PACKAGE=
TECPEY_IOS_BUNDLE_ID=
TECPEY_FCM_SERVER_KEY=
TECPEY_APNS_KEY_ID=
TECPEY_APNS_TEAM_ID=
TECPEY_APNS_BUNDLE_ID=
TECPEY_APNS_PRIVATE_KEY=

# Cookie security override (optional — inferred from NEXT_PUBLIC_SITE_URL by default).
# Set to "true" to force Secure flag on cookies in all environments.
# Set to "false" to force Secure off (e.g. HTTP-only local testing).
TECPEY_COOKIE_SECURE=

# Session configuration (optional — defaults shown).
TECPEY_SESSION_MAX_AGE=30d
TECPEY_SESSION_MAX_AGE_SECONDS=2592000

# Feature flags — controls which products are active at runtime.
# Default values (when env var is absent):
#   academy.enabled        → true   (academy is on by default)
#   exchange.enabled       → true   (exchange is on by default)
#   social.enabled         → false  (social is off by default)
#   mentor.enabled         → true   (AI mentor is on by default)
#   marketplace.enabled    → false  (future product, off by default)
# Set to "true" or "false" to override the default.
FEATURE_ACADEMY_ENABLED=
FEATURE_EXCHANGE_ENABLED=
FEATURE_SOCIAL_ENABLED=
FEATURE_MENTOR_ENABLED=
FEATURE_MARKETPLACE_ENABLED=

# Email delivery — transactional emails (verification, reset, certificate delivery).
# EMAIL_PROVIDER options: resend | sendgrid | dev | none
#   "resend"    → uses RESEND_API_KEY (recommended; no additional packages required)
#   "sendgrid"  → uses SENDGRID_API_KEY
#   "dev"       → logs emails to server console; never delivers (default in non-production)
#   "none"      → explicitly disables email delivery even in production
# In production with no EMAIL_PROVIDER set, email delivery will fail with an error log.
EMAIL_PROVIDER=dev
EMAIL_FROM=TecPey <noreply@tecpey.ir>
RESEND_API_KEY=
SENDGRID_API_KEY=

# Observability — error tracking provider (Phase 26).
# Options: sentry | betterstack | none (default: none — structured error logs only)
# sentry:       requires @sentry/nextjs package + NEXT_PUBLIC_SENTRY_DSN
# betterstack:  requires BETTERSTACK_SOURCE_TOKEN; uses fetch (no extra package)
ERROR_TRACKING_PROVIDER=none
BETTERSTACK_SOURCE_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Alerting webhook — generic outbound webhook for critical alerts (DB_DOWN, API_ERROR_SPIKE, etc.)
# Connect Slack, PagerDuty, Discord, or a custom relay service at the URL level.
# Leave empty to disable webhook delivery (alerts still appear in structured logs).
ALERT_WEBHOOK_URL=

# Build metadata — injected at deploy time for the /api/health endpoint.
NEXT_PUBLIC_GIT_COMMIT=
NEXT_PUBLIC_BUILD_VERSION=

# CSP connect-src tightening (Phase 27).
# Space-separated list of additional origins to allow in connect-src.
# Example: "https://analytics.mysite.com wss://events.mysite.com"
# Primary origins are derived automatically from NEXT_PUBLIC_API_BACKEND_URL and NEXT_PUBLIC_API_SOCKET_URL.
NEXT_PUBLIC_EXTRA_CONNECT_SRC=

# TecPey Production Environment - Ubuntu 24.04
# Copy this file to .env.production or .env.local on the server and fill the CHANGE_ME values.
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://tecpey.ir
TECPEY_COOKIE_SECURE=true
NEXT_PUBLIC_API_URL=https://my.tecpey.ir

# TecPey AI Mentor
# You will add the real key on the server. Never commit the real key.
OPENAI_API_KEY=
AI_MENTOR_MODEL=gpt-4o-mini
AI_MENTOR_FALLBACK_MODEL=gpt-4.1-mini
AI_MENTOR_MAX_OUTPUT_TOKENS=700
AI_MENTOR_TEMPERATURE=0.2
AI_MENTOR_BUDGET_NOTE=gpt-4o-mini is the low-cost default; upgrade to gpt-4.1-mini or gpt-5.4-mini only if needed.

# Production secrets - generate strong values before launch.
TECPEY_ACADEMY_AUTH_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_ACADEMY_AUTH
TECPEY_SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_STUDENT_SESSIONS
CERTIFICATE_SIGNING_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_CERTIFICATE_SIGNING

# Persistent data layer
# Keep false/empty on production; local localhost is allowed only for testing.
TECPEY_ENABLE_LOCAL_ACADEMY_STORAGE=
DATABASE_URL=postgresql://tecpey:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/tecpey
REDIS_URL=redis://127.0.0.1:6379

# Rate limiting — REQUIRED in production for multi-instance coordination.
# Configure one of:
#   UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN  (Upstash, preferred)
#   REDIS_REST_URL + REDIS_REST_TOKEN                   (generic Redis REST API)
# Without REST, rate limits are per-instance memory only.
# Set TECPEY_ALLOW_MEMORY_RATE_LIMIT=1 to opt in to per-instance rate limiting
# on a single-server production deployment.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_REST_URL=
REDIS_REST_TOKEN=
TECPEY_ALLOW_MEMORY_RATE_LIMIT=

# Academy lead capture
ACADEMY_LEADS_WEBHOOK_URL=
SPECIALIZED_ACADEMY_WEBHOOK_URL=

# News engine controls
CRYPTO_NEWS_CACHE_TTL_SECONDS=900
CRYPTO_NEWS_MAX_ITEMS=24
CRYPTO_NEWS_ENABLE_LIVE=true

# TecPey market backend - replace after backend/API handoff.
NEXT_PUBLIC_API_BACKEND_URL=https://CHANGE_ME_ADMIN_MARKET_BACKEND
NEXT_PUBLIC_API_SOCKET_URL=wss://CHANGE_ME_MARKET_SOCKET/spot

# TecPey Global Learning OS / Command Center
TECPEY_ADMIN_TOKEN=
TECPEY_NOTIFICATION_DEFAULT_CHANNELS=in_app,push,email,telegram
TECPEY_PUSH_PROVIDER=firebase
TECPEY_ANDROID_PACKAGE=
TECPEY_IOS_BUNDLE_ID=
TECPEY_FCM_SERVER_KEY=
TECPEY_APNS_KEY_ID=
TECPEY_APNS_TEAM_ID=
TECPEY_APNS_BUNDLE_ID=
TECPEY_APNS_PRIVATE_KEY=

# Internal price-feed status endpoint token.
# Required for POST /api/internal/price-feed-status.
TECPEY_PRICE_FEED_STATUS_TOKEN=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_PRICE_FEED_STATUS

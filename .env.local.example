# TecPey Local Development Environment
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
TECPEY_COOKIE_SECURE=false
NEXT_PUBLIC_API_URL=https://my.tecpey.ir

# TecPey AI Mentor
# Put your real key only in .env.local. Keep this example empty.
OPENAI_API_KEY=
AI_MENTOR_MODEL=gpt-4o-mini
AI_MENTOR_FALLBACK_MODEL=gpt-4.1-mini
AI_MENTOR_MAX_OUTPUT_TOKENS=700
AI_MENTOR_TEMPERATURE=0.2
AI_MENTOR_BUDGET_NOTE=gpt-4o-mini is the low-cost default; upgrade to gpt-4.1-mini or gpt-5.4-mini only if needed.

# Local secrets for signed student sessions and verifiable certificates.
TECPEY_ACADEMY_AUTH_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_FOR_ACADEMY_AUTH
TECPEY_SESSION_SECRET=CHANGE_ME_LOCAL_64_CHAR_RANDOM_SECRET_FOR_SESSIONS
CERTIFICATE_SIGNING_SECRET=CHANGE_ME_LOCAL_64_CHAR_RANDOM_SECRET_FOR_CERTIFICATES

# Optional local integrations
# Allows local JSON storage for academy auth/profile when testing with npm run start on localhost.
TECPEY_ENABLE_LOCAL_ACADEMY_STORAGE=true
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ACADEMY_LEADS_WEBHOOK_URL=
SPECIALIZED_ACADEMY_WEBHOOK_URL=

# Market backend placeholders. Replace when final backend/API is ready.
NEXT_PUBLIC_API_BACKEND_URL=https://CHANGE_ME_ADMIN_MARKET_BACKEND
NEXT_PUBLIC_API_SOCKET_URL=wss://CHANGE_ME_MARKET_SOCKET/spot

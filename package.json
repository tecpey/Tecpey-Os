{
  "name": "tecpey-os",
  "version": "0.1.0",
  "private": true,
  "description": "TecPey Financial Education and Digital Asset Operating System",
  "homepage": "https://tecpey.ir",
  "repository": {
    "type": "git",
    "url": "https://github.com/tecpey/Tecpey-Os.git"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:next": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npx tsc --noEmit",
    "prod:build": "npm ci --no-audit --no-fund && npm run env:check && npm run build",
    "prod:start": "NODE_ENV=production tsx server.ts",
    "health": "node scripts/check-health.mjs",
    "env:check": "node scripts/validate-env.mjs",
    "guard:academy-authority": "node scripts/check-academy-authority.mjs",
    "npm:registry:fix": "npm config set registry https://registry.npmjs.org/ && npm config delete proxy || true && npm config delete https-proxy || true",
    "clean": "rm -rf node_modules .next",
    "clean:hard": "rm -rf node_modules .next package-lock.json && npm cache clean --force",
    "install:safe": "npm run npm:registry:fix && npm install --registry=https://registry.npmjs.org/ --no-audit --no-fund",
    "ci:safe": "npm run npm:registry:fix && npm ci --registry=https://registry.npmjs.org/ --no-audit --no-fund",
    "release:check": "npm run env:check && npm run check && npm run build",
    "qa:academy-core": "node scripts/qa-academy-core.mjs",
    "qa:offline-core": "node scripts/qa-offline-core.mjs",
    "qa:core": "npm run qa:academy-core && npm run qa:offline-core && npm run qa:phase5-core && npm run qa:phase6-core",
    "qa:phase5-core": "node scripts/qa-phase5-core.mjs",
    "qa:phase6-core": "node scripts/qa-phase6-core.mjs",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@swc/helpers": "0.5.23",
    "@tanstack/react-query": "^5.100.10",
    "bullmq": "^5.79.2",
    "chart.js": "^4.5.1",
    "decimal.js": "^10.6.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide": "^1.11.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.13.1",
    "postcss": "^8.5.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0 <11.0.0"
  }
}

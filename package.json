{
  "name": "tecpey-os",
  "version": "0.1.0",
  "private": true,
  "description": "TecPey Financial Education and Digital Asset Operating System",
  "homepage": "https://tecpey.ir",
  "repository": {
    "type": "git",
    "url": "https://github.com/tecpey/Tecpey-Os.git"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:next": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npx tsc --noEmit",
    "prod:build": "npm ci --no-audit --no-fund && npm run env:check && npm run build",
    "prod:start": "NODE_ENV=production tsx server.ts",
    "health": "node scripts/check-health.mjs",
    "env:check": "node scripts/validate-env.mjs",
    "db:migrate": "tsx scripts/run-database-migrations.ts",
    "ui:check": "node scripts/check-ui-style-authority.mjs",
    "ui:public:check": "node scripts/check-public-ui-foundation.mjs",
    "ui:runtime:dev": "node scripts/check-ui-runtime.mjs --dev",
    "ui:runtime:prod": "node scripts/check-ui-runtime.mjs --prod",
    "redis:safety:check": "node scripts/check-redis-safety-authority.mjs",
    "test:redis-safety": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/runtime/redis-pubsub-safety.test.ts",
    "notifications:check": "node scripts/check-notification-persistence-authority.mjs",
    "notifications:runtime:check": "node scripts/check-notification-runtime-authority.mjs",
    "notifications:producers:check": "node scripts/check-notification-producer-authority.mjs",
    "notifications:domain:check": "node scripts/check-notification-domain-outbox-authority.mjs",
    "notifications:worker:in-app": "tsx scripts/run-notification-in-app-worker.ts",
    "notifications:worker:domain": "tsx scripts/run-notification-domain-worker.ts",
    "auth:check": "node scripts/check-auth-session-authority.mjs && node scripts/check-session-authority-completion.mjs && node scripts/check-strict-revocation-authority.mjs",
    "test:auth-session": "NODE_ENV=test node --import tsx --test --test-force-exit 'src/tests/security/auth-*.test.ts'",
    "auth:revocations:repair": "tsx scripts/reconcile-session-revocations.ts",
    "ai:trust:check": "node scripts/check-ai-mentor-trust-boundary.mjs",
    "test:ai-mentor-trust": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/security/ai-mentor-provider.test.ts src/tests/security/ai-mentor-trust-boundary.test.ts src/tests/security/ai-mentor-trust-store-postgres.test.ts",
    "ai:redteam:check": "npm run ai:trust:check && npm run test:ai-mentor-trust",
    "withdrawals:check": "node scripts/run-withdrawal-authority-checks.mjs && node scripts/check-withdrawal-prebroadcast-evidence.mjs",
    "test:withdrawal-admission": "node --import tsx --test 'src/tests/security/withdrawal-admission*.test.ts' 'src/tests/security/withdrawal-external-effect*.test.ts' 'src/tests/security/withdrawal-price-producer.test.ts' 'src/tests/security/withdrawal-settlement-postgres.test.ts'",
    "offline:check": "node scripts/check-offline-sync-authority.mjs && node scripts/check-offline-queue-capacity.mjs",
    "test:offline-sync": "NODE_ENV=test node --import tsx --test --test-force-exit 'src/tests/security/offline-sync*.test.ts'",
    "offline:reconcile": "tsx scripts/reconcile-offline-sync-commands.ts",
    "academy:progress:check": "node scripts/check-academy-authority-boundary.mjs",
    "test:academy-progress": "NODE_ENV=test node --import tsx --test --test-force-exit 'src/tests/security/academy-progress*.test.ts'",
    "crm:check": "node scripts/check-crm-lead-authority.mjs",
    "test:crm-leads": "NODE_ENV=test node --import tsx --test --test-force-exit 'src/tests/security/crm-lead*.test.ts'",
    "crm:worker": "tsx scripts/run-crm-lead-delivery-worker.ts",
    "crm:retention": "tsx scripts/run-crm-lead-retention.ts",
    "exchange:check": "node scripts/check-exchange-order-admission.mjs && node scripts/check-exchange-order-evidence.mjs",
    "test:exchange-order-authority": "NODE_ENV=test node --import tsx --test 'src/tests/security/exchange-order*.test.ts' 'src/tests/trading/order-admission*.test.ts'",
    "exchange:worker": "tsx scripts/run-exchange-order-worker.ts",
    "api:security:check": "node scripts/check-api-security-manifest.mjs",
    "test:api-security-manifest": "NODE_ENV=test node --import tsx --test scripts/api-security-body-limit-policy.test.mjs scripts/api-security-body-boundary.test.mjs scripts/api-security-source-evidence.test.mjs scripts/api-security-runtime-evidence.test.mjs scripts/api-security-strict-revocation-evidence.test.mjs scripts/api-security-operation-override-policy.test.mjs scripts/api-security-manifest-policy.test.mjs scripts/api-security-manifest-reviewed-deltas.test.mjs src/tests/security/api-validation-cache.test.ts",
    "test:api-command-idempotency": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/security/api-command-idempotency-postgres.test.ts",
    "idempotency:retention": "tsx scripts/purge-api-command-receipts.ts",
    "audit:sensitive:check": "node scripts/check-sensitive-mutation-audit-authority.mjs && node scripts/check-two-factor-audit-authority.mjs && node scripts/check-webauthn-credential-audit-authority.mjs",
    "test:sensitive-mutation-audit": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/security/sensitive-mutation-audit-routes.test.ts src/tests/security/sensitive-mutation-audit-postgres.test.ts src/tests/security/api-key-transactional-audit-postgres.test.ts src/tests/security/password-rotation-audit-postgres.test.ts src/tests/security/two-factor-transactional-audit-postgres.test.ts src/tests/security/webauthn-transactional-audit-postgres.test.ts",
    "audit:hygiene": "node scripts/audit-repository-hygiene.mjs",
    "audit:hygiene:json": "node scripts/audit-repository-hygiene.mjs --json",
    "npm:registry:fix": "npm config set registry https://registry.npmjs.org/ && npm config delete proxy || true && npm config delete https-proxy || true",
    "clean": "rm -rf node_modules .next",
    "clean:hard": "rm -rf node_modules .next package-lock.json && npm cache clean --force",
    "install:safe": "npm run npm:registry:fix && npm install --registry=https://registry.npmjs.org/ --no-audit --no-fund",
    "ci:safe": "npm run npm:registry:fix && npm ci --registry=https://registry.npmjs.org/ --no-audit --no-fund",
    "release:check": "npm run env:check && npm run check && npm run ui:check && npm run ui:public:check && npm run redis:safety:check && npm run test:redis-safety && npm run auth:check && npm run test:auth-session && npm run ai:redteam:check && npm run custody:check && npm run test:custody-gate && npm run withdrawals:check && npm run test:withdrawal-admission && npm run test:api-command-idempotency && npm run audit:sensitive:check && npm run test:sensitive-mutation-audit && npm run offline:check && npm run test:offline-sync && npm run academy:progress:check && npm run test:academy-progress && npm run crm:check && npm run test:crm-leads && npm run exchange:check && npm run test:exchange-order-authority && npm run bounded-body:check && npm run test:bounded-body && npm run api:security:check && npm run test:api-security-manifest && npm run notifications:check && npm run notifications:runtime:check && npm run notifications:producers:check && npm run notifications:domain:check && npm run build && npm run ui:runtime:prod",
    "qa:academy-core": "node scripts/qa-academy-core.mjs",
    "qa:offline-core": "node scripts/qa-offline-core.mjs",
    "qa:core": "npm run qa:academy-core && npm run qa:offline-core && npm run qa:phase5-core && npm run qa:phase6-core",
    "qa:phase5-core": "node scripts/qa-phase5-core.mjs",
    "qa:phase6-core": "node scripts/qa-phase6-core.mjs",
    "test": "NODE_ENV=test node --import tsx --test 'src/tests/**/*.test.ts'",
    "bounded-body:check": "node scripts/check-bounded-request-body-authority.mjs",
    "test:bounded-body": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/security/bounded-request-body.test.ts",
    "custody:check": "node scripts/check-wallet-custody-launch-gate.mjs",
    "test:custody-gate": "NODE_ENV=test node --import tsx --test --test-force-exit src/tests/wallet/custody-launch-policy.test.ts src/tests/wallet/custody-env-validation.test.ts src/tests/wallet/keystore-runtime-guard.test.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@swc/helpers": "0.5.23",
    "@tanstack/react-query": "^5.100.10",
    "bullmq": "^5.79.2",
    "chart.js": "^4.5.1",
    "decimal.js": "^10.6.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.11.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.13.1",
    "postcss": "^8.5.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0 <11.0.0"
  }
}
